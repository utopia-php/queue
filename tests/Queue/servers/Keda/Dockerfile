FROM php:8.4-cli-alpine

WORKDIR /app

RUN apk add --no-cache --virtual .build-deps $PHPIZE_DEPS \
    && pecl install redis \
    && docker-php-ext-enable redis \
    && apk del .build-deps

COPY composer.json composer.lock ./
COPY vendor ./vendor
COPY src ./src
COPY tests ./tests

CMD ["php", "tests/Queue/servers/Keda/worker.php"]
